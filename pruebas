Write-Host "=== DIAGNOSTICO ===" 
Write-Host "[1] Language Mode:"
$ExecutionContext.SessionState.LanguageMode

Write-Host "[2] .NET Framework:"
[System.Runtime.InteropServices.RuntimeInformation]::FrameworkDescription

Write-Host "[3] Execution Policy:"
Get-ExecutionPolicy

Write-Host "[4] ¿Puedes leer clr.dll?"
try {
    $bytes = [System.IO.File]::ReadAllBytes("C:\Windows\Microsoft.NET\Framework64\v4.0.30319\clr.dll")
    Write-Host "SI - tamaño: $('{0:N0}' -f $bytes.Length) bytes"
} catch {
    Write-Host "NO - Error: $_"
}

Write-Host "[5] ¿Eres Admin?"
([Security.Principal.WindowsIdentity]::GetCurrent().Groups -contains [Security.Principal.SecurityIdentifier]"S-1-5-32-544")
